#!/usr/bin/env python3
"""
EduPulse quick launcher for recording.

This is a convenience wrapper that sets sensible defaults for the current
environment (Pi 4 on SD card, Option A testing, test_recordings folder).

Usage examples:
    ./edupulse-record                  # 60s recording with default settings
    ./edupulse-record --duration 300   # 5 minute recording
    ./edupulse-record --preview        # Check levels without writing
    ./edupulse-record --label "morning-test" --duration 120
"""

import sys
from pathlib import Path

# Ensure we can import from the capture directory
sys.path.insert(0, str(Path(__file__).parent))

from record_session import record_session, DEFAULT_DATA_DIR

import argparse

def main():
    parser = argparse.ArgumentParser(description="EduPulse Quick Recorder (convenience wrapper)")
    parser.add_argument("--duration", type=int, default=60,
                        help="Recording duration in seconds (default: 60)")
    parser.add_argument("--data-dir", type=Path, default=DEFAULT_DATA_DIR,
                        help=f"Output directory (default: {DEFAULT_DATA_DIR})")
    parser.add_argument("--label", type=str, default=None,
                        help="Optional label for this session")
    parser.add_argument("--preview", action="store_true",
                        help="Preview levels only (no files written)")
    parser.add_argument("--device", type=int, default=None,
                        help="Specific ALSA device index")

    args = parser.parse_args()

    print("EduPulse Quick Recorder")
    print("=======================")
    print(f"Duration : {args.duration}s")
    print(f"Data dir : {args.data_dir}")
    if args.label:
        print(f"Label    : {args.label}")
    if args.preview:
        print("Mode     : PREVIEW")
    print()

    record_session(
        data_dir=args.data_dir,
        duration=args.duration,
        device=args.device,
        label=args.label,
        preview=args.preview
    )


if __name__ == "__main__":
    main()